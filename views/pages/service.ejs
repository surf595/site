<%- include('../partials/head') %>
<%- include('../partials/header') %>
<% const isPrimaryService = service.slug === "individual"; %>
<section class="page-shell">
  <div class="page-hero">
    <div class="page-hero-grid">
      <div class="page-hero-copy">
        <p class="about-kicker"><%= isPrimaryService ? "Основная услуга MVP" : "Дополнительный формат" %></p>
        <h1><%= service.title %></h1>
        <p class="page-summary"><%= service.summary %></p>
        <p><%= service.details %></p>
        <p><a class="btn" href="/booking#booking-form"><%= isPrimaryService ? "Выбрать время" : "Перейти к записи" %></a> <a class="btn secondary" href="/contacts">Задать вопрос</a></p>
      </div>

      <div class="page-stat-grid">
        <article class="page-stat">
          <span>Стоимость</span>
          <strong><%= service.price || (isPrimaryService ? "60 €" : "По согласованию") %></strong>
          <p><%= service.sessionLength || "50 минут" %></p>
        </article>
        <article class="page-stat">
          <span>Формат</span>
          <strong><%= service.format || (isPrimaryService ? "Очно и онлайн" : "Обсуждается отдельно") %></strong>
          <p><%= isPrimaryService ? "вы выбираете до отправки формы" : (service.availability || "после первичного контакта") %></p>
        </article>
        <article class="page-stat">
          <span>Правила</span>
          <strong>24 часа</strong>
          <p>базовое правило переноса и отмены вынесено в отдельные условия</p>
        </article>
      </div>
    </div>
  </div>

  <% if (isPrimaryService) { %>
    <section class="page-section">
      <div class="page-section-head">
        <p class="about-kicker">Для кого подходит</p>
        <h2>Перед записью можно быстро понять, насколько этот формат сейчас уместен</h2>
      </div>

      <div class="feature-grid feature-grid-2">
        <article class="feature-card">
          <h3>Обычно подходит, если сейчас важны</h3>
          <ul class="bullet-list">
            <% (service.worksWith || []).forEach((item) => { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </article>

        <article class="feature-card">
          <h3>Нужен другой или дополнительный маршрут, если речь о</h3>
          <ul class="bullet-list">
            <% (service.notFor || []).forEach((item) => { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </article>
      </div>
    </section>

    <section class="page-section page-section-soft">
      <div class="page-section-head">
        <p class="about-kicker">Как проходит работа</p>
        <h2>Первая встреча нужна не для давления, а для ориентации</h2>
      </div>

      <div class="feature-grid feature-grid-2">
        <article class="feature-card">
          <h3>Первая встреча</h3>
          <p><%= service.firstSession %></p>
        </article>
        <article class="feature-card">
          <h3>Ритм и длительность</h3>
          <p><%= service.frequency %></p>
        </article>
        <article class="feature-card">
          <h3>Стоимость и условия</h3>
          <p><%= service.price %> за сессию <%= service.sessionLength %>. Правила оплаты, переноса и отмены собраны отдельно на странице <a href="/terms">Условия</a>.</p>
        </article>
        <article class="feature-card">
          <h3>Если хочется проверить рамки заранее</h3>
          <p>До записи можно спокойно открыть раздел <a href="/about/boundaries">Границы и безопасность</a> и legal-страницы без потери маршрута.</p>
        </article>
      </div>
    </section>
  <% } else { %>
    <section class="page-section">
      <div class="page-section-head">
        <p class="about-kicker">Как подключается формат</p>
        <h2>Этот сценарий не должен ломать основную первую запись</h2>
      </div>

      <div class="feature-grid feature-grid-2">
        <article class="feature-card">
          <h3>Для кого</h3>
          <p><%= service.audience %></p>
        </article>
        <article class="feature-card">
          <h3>Как проходит</h3>
          <p><%= service.process %></p>
        </article>
        <article class="feature-card">
          <h3>Как обсудить уместность</h3>
          <p><%= service.availability || "Лучше сначала коротко описать ситуацию, чтобы понять, подходит ли именно этот формат." %></p>
        </article>
        <article class="feature-card">
          <h3>Без лишней перегрузки</h3>
          <p>Если формат пока неочевиден, можно всё равно начать с обычной записи или организационного вопроса, а решение уточнить позже.</p>
        </article>
      </div>
    </section>
  <% } %>

  <section class="cta-panel">
    <div class="page-section-head">
      <p class="about-kicker">Следующий шаг</p>
      <h2><%= isPrimaryService ? "Если формат откликается, можно сразу перейти к слотам и минимальной форме" : "Если формат только частично откликается, маршрут всё равно остаётся простым" %></h2>
    </div>
    <p class="cta-panel-copy"><%= isPrimaryService ? "Даже если пока сложно подробно рассказывать о себе, можно оставить только нужный минимум и при необходимости сначала открыть privacy, consent или terms." : "Можно либо обсудить вопрос через контакты, либо всё равно начать с первой записи и уточнить формат уже в живом контакте." %></p>
    <p><a class="btn" href="/booking#booking-form">Перейти к записи</a> <a class="btn secondary" href="/services">Вернуться к услугам</a></p>
  </section>
<section class="hero">
  <h1><%= service.title %></h1>
  <p><%= service.details %></p>
  <p class="service-meta"><strong><%= service.price %></strong> · <%= service.duration %></p>
  <p><a class="btn" href="/booking">Записаться</a></p>
</section>
<section class="grid two">
  <article class="card"><h2>Для кого</h2><p>Для взрослых, которым важно бережно разобрать текущее состояние и найти устойчивый рабочий ритм.</p></article>
  <article class="card"><h2>Как проходит</h2><p>Первая встреча — ориентировка и контракт. Далее — регулярные сессии с понятными рамками.</p></article>
  <article class="card"><h2>Оплата</h2><p>Оплата через Kairos Therapy OÜ. Подробные условия — на странице <a href="/terms">Условия</a>.</p></article>
  <article class="card"><h2>Вопросы</h2><p>Ответы на частые вопросы: <a href="/faq">FAQ</a>.</p></article>
</section>
<%- include('../partials/footer') %>
