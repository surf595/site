<%- include('../partials/head') %>
<%- include('../partials/header') %>
<%
  const primaryService = services.find((item) => item.status === "primary") || services[0];
  const secondaryServices = services.filter((item) => item.slug !== primaryService.slug);
%>
<section class="page-shell">
  <div class="page-hero">
    <div class="page-hero-grid">
      <div class="page-hero-copy">
        <p class="about-kicker">Форматы работы</p>
        <h1>Страница услуг помогает быстро выйти на нужный следующий шаг, а не потеряться в выборе</h1>
        <p class="page-summary">В MVP основной маршрут ведёт в индивидуальную работу для взрослых. Дополнительные форматы можно обсудить отдельно, если после первичного контакта станет ясно, что они подходят лучше.</p>
        <p><a class="btn" href="/services/<%= primaryService.slug %>">Открыть основную услугу</a> <a class="btn secondary" href="/contacts">Уточнить формат</a></p>
      </div>

      <div class="page-stat-grid">
        <article class="page-stat">
          <span>Основной маршрут</span>
          <strong><%= primaryService.title %></strong>
          <p><%= primaryService.price || "60 €" %> · <%= primaryService.sessionLength || "50 минут" %></p>
        </article>
        <article class="page-stat">
          <span>Формат</span>
          <strong><%= primaryService.format || "Онлайн и очно" %></strong>
          <p>подтверждается до начала регулярной работы</p>
        </article>
        <article class="page-stat">
          <span>До записи</span>
          <strong>Не больше 2 шагов</strong>
          <p>из услуги можно сразу перейти к форме записи или к организационному вопросу</p>
        </article>
      </div>
    </div>
  </div>

  <section class="page-section">
    <div class="page-section-head">
      <p class="about-kicker">P0-маршрут</p>
      <h2>Для MVP приоритетен один понятный путь: услуга -> запись -> подтверждение</h2>
    </div>

    <article class="feature-card feature-card-primary">
      <span class="feature-index">Основная услуга</span>
      <h2><%= primaryService.title %></h2>
      <p class="service-card-summary"><%= primaryService.summary %></p>
      <div class="stack-list">
        <p><strong>Для кого:</strong> <%= primaryService.audience %></p>
        <p><strong>Как проходит:</strong> <%= primaryService.process %></p>
        <p><strong>Что важно заранее:</strong> стоимость, длительность, правила переноса и legal-ссылки видны до отправки формы.</p>
      </div>
      <p><a class="btn" href="/services/<%= primaryService.slug %>">Открыть страницу услуги</a> <a class="btn secondary" href="/booking#booking-form">Сразу к записи</a></p>
    </article>
  </section>

  <section class="page-section page-section-soft">
    <div class="page-section-head">
      <p class="about-kicker">Дополнительные форматы</p>
      <h2>Они остаются на сайте, но не размывают основной сценарий первой записи</h2>
      <p class="muted">Если после первичного контакта станет понятно, что нужен другой формат, это можно отдельно обсудить без давления и лишних переходов.</p>
    </div>

    <div class="feature-grid feature-grid-2">
      <% secondaryServices.forEach((service) => { %>
        <article class="feature-card service-link-card service-link-card-secondary">
          <span class="service-badge">Дополнительный формат</span>
          <h3><%= service.title %></h3>
          <p class="service-card-summary"><%= service.summary %></p>
          <div class="stack-list">
            <p><strong>Для кого:</strong> <%= service.audience %></p>
            <p><strong>Как проходит:</strong> <%= service.process %></p>
            <% if (service.availability) { %><p><strong>Как подключается:</strong> <%= service.availability %>.</p><% } %>
          </div>
          <p><a class="btn secondary" href="/services/<%= service.slug %>">Подробнее</a> <a class="btn secondary" href="/contacts">Обсудить формат</a></p>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="cta-panel">
    <div class="page-section-head">
      <p class="about-kicker">Если формат пока неочевиден</p>
      <h2>Можно не решать всё заранее и всё равно не выпадать из маршрута</h2>
    </div>
    <p class="cta-panel-copy">Если вы чувствуете только общее напряжение или неопределённость, этого уже достаточно для первого шага. На старте не требуется точная самодиагностика.</p>
    <p><a class="btn secondary" href="/faq">Сначала посмотреть FAQ</a> <a class="btn" href="/booking#booking-form">Перейти к записи</a></p>
  </section>
</section>
<%- include('../partials/footer') %>
