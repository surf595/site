<%- include('../partials/head') %>
<%- include('../partials/header') %>
<section class="hero">
  <h1>Услуги</h1>
  <p>Выберите формат, который лучше подходит вашему запросу.</p>
</section>
<section class="grid two">
  <% services.forEach((s) => { %>
    <article class="card">
      <h2><%= s.title %></h2>
      <p><%= s.summary %></p>
      <p><a class="btn" href="/services/<%= s.slug %>">Выбрать формат</a></p>
    </article>
  <% }) %>
</section>
<%- include('../partials/footer') %>
