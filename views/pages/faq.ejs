<%- include('../partials/head') %>
<%- include('../partials/header') %>
<section class="legal faq-page">
  <div class="faq-hero">
    <p class="privacy-eyebrow">FAQ</p>
    <h1>FAQ перед первой записью</h1>
    <p class="faq-lead">Здесь собраны типовые вопросы о начале терапии, формате работы, конфиденциальности и организационных условиях. Если после чтения уже хватает ясности, до записи остаётся один переход.</p>
    <p><a class="btn secondary" href="/services/individual">Открыть услугу</a> <a class="btn" href="/booking#booking-form">Записаться</a></p>
  </div>

  <% faqSections.forEach((section, sectionIndex) => { %>
    <section class="faq-section">
      <h2><%= section.title %></h2>
      <div class="faq-accordion">
        <% section.items.forEach((item, itemIndex) => { %>
          <details class="faq-item" <%= sectionIndex === 0 && itemIndex === 0 ? 'open' : '' %>>
            <summary><span><%= item.q %></span></summary>
            <div class="faq-answer">
              <p><%= item.a %></p>
            </div>
          </details>
        <% }) %>
      </div>
    </section>
  <% }) %>

  <section class="faq-closing">
    <h2>Не нашли ответ на свой вопрос?</h2>
    <p>Можно либо задать организационный вопрос напрямую через контакты, либо всё равно перейти к записи и использовать legal-страницы уже внутри сценария.</p>
    <p><a class="btn secondary" href="/contacts">Контакты</a> <a class="btn" href="/booking#booking-form">Записаться</a></p>
  </section>
</section>
<%- include('../partials/footer') %>
