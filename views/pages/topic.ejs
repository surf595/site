<%- include('../partials/head') %>
<%- include('../partials/header') %>
<section class="topic-page">
  <div class="topic-hero">
    <p><a class="topic-back" href="/#topics">← Все направления</a></p>
    <div class="topic-hero-grid">
      <div>
        <p class="about-kicker">Направление работы</p>
        <h1><%= topic.title %></h1>
      </div>
      <div class="topic-hero-copy">
        <p><%= topic.heroExcerpt %></p>
      </div>
    </div>
  </div>

  <div class="topic-layout">
    <aside class="topic-sidebar">
      <p class="about-kicker">Другие темы</p>
      <nav class="topic-nav" aria-label="Другие темы">
        <% topics.filter((item) => item.slug !== topic.slug).forEach((item) => { %>
          <a href="/topics/<%= item.slug %>"><%= item.title %></a>
        <% }) %>
      </nav>
    </aside>

    <article class="topic-article">
      <% topic.body.forEach((paragraph) => { %>
        <p><%= paragraph %></p>
      <% }) %>

      <div class="topic-cta">
        <h2>Обсудить запрос</h2>
        <p><%= topic.discuss %></p>
        <p><a class="btn secondary" href="/contacts">Связаться</a> <a class="btn" href="/booking">Записаться</a></p>
      </div>
    </article>
  </div>
<section class="hero">
  <h1><%= topic.title %></h1>
  <p><%= topic.excerpt %></p>
  <p><a class="btn" href="/booking">Записаться</a> <a class="btn secondary" href="/about/approach">Подход</a></p>
</section>

<% if (topic.body && topic.body.length) { %>
<section class="topic-body">
  <% topic.body.forEach((block) => { %>
    <article class="card">
      <h2><%= block.heading %></h2>
      <p><%= block.text %></p>
    </article>
  <% }) %>
</section>
<% } %>

<section class="card">
  <h2>Следующий шаг</h2>
  <p>Если тема вам откликается — можно начать с первой встречи. Она ни к чему не обязывает: мы просто знакомимся и уточняем запрос.</p>
  <p><a class="btn" href="/booking">Записаться на первую встречу</a></p>
</section>
<%- include('../partials/footer') %>
