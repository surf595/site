# Server
PORT=3000
SITE_URL=https://kairos.ee

# Session (generate a strong random string for production)
SESSION_SECRET=change-me-to-a-long-random-string

# SMTP — email for booking notifications
# Gmail: enable "App Password" in Google Account → Security
# Or use any SMTP provider (SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# Admin email — receives booking notifications
ADMIN_EMAIL=info@kairos.ee
